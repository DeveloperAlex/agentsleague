# Student Certification Readiness Multi-Agent System
# Copy this file to .env and fill in values

# Microsoft Foundry project endpoint
FOUNDRY_PROJECT_ENDPOINT=https://<name>-resource.services.ai.azure.com/api/projects/<name>
AZURE_EXISTING_AIPROJECT_ENDPOINT=https://<name>-resource.services.ai.azure.com/api/projects/<name>

# Model deployment name (available in your Foundry project)
FOUNDRY_MODEL_DEPLOYMENT_NAME=gpt-4.1-mini

# Foundry project API key (use 'az login' instead)
# FOUNDRY_API_KEY=<your-foundry-api-key>

# Microsoft Learn MCP tool name (as registered in Foundry Tools)
# MCP_TOOL_NAME=mslearn-mcp-server # No longer used - because Tools were set directly in Foundry portal (ai.azure.com).

PYTHONDONTWRITEBYTECODE="1"
